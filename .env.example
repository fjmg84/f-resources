# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL used by Auth.js to build OAuth callback URLs.
# Local:  http://localhost:3000
# Prod:   https://your-domain.com
AUTH_URL=

# Google OAuth (Google Cloud Console)
# Authorized redirect URIs must include:
# - http://localhost:3000/api/auth/callback/google
# - https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Legacy SvelteKit variable names still supported temporarily:
# CLIENT_ID=
# SECRET_ID=

# Hygraph (GraphQL CMS)
GRAPHQL_URL=
HYGRAPH_MUTATION_TOKEN=

# Fallback image when article has no image
NOT_IMAGE=https://your-fallback-image-url.com/image.png
